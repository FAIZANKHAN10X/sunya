# =============================================================================
# Public client env (bundled into the browser — NEVER put secrets here)
# =============================================================================

# Google Tag Manager container ID (required in production)
# Format: GTM- followed by alphanumeric characters only
NEXT_PUBLIC_GTM_ID=GTM-M9S5TG62

# =============================================================================
# Server-only secrets (if added later): use names WITHOUT NEXT_PUBLIC_
# and read them only in Server Components / Route Handlers / server actions.
# Example (do not commit real values):
#   DATABASE_URL=
#   API_SECRET=
# =============================================================================

# GA4 Measurement ID is configured inside GTM only — the app never loads gtag.js
# or reads a GA4 env var. Keep the ID in Tag Manager, not in NEXT_PUBLIC_*.
# Reference (not used by app code): G-6WRFGZP7LN
